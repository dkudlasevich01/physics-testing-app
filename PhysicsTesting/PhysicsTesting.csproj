<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>PhysicsTesting</AssemblyName>
    <RootNamespace>PhysicsTesting</RootNamespace>
    <StartupObject>PhysicsTesting.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.SQLite" Version="1.0.118" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.118" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Forms\MainForm.Designer.cs">
      <DependentUpon>MainForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Forms\TestForm.Designer.cs">
      <DependentUpon>TestForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Forms\ResultsForm.Designer.cs">
      <DependentUpon>ResultsForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Forms\StatisticsForm.Designer.cs">
      <DependentUpon>StatisticsForm.cs</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
